{% layout "./base.liquid" %}

{% block content %}
  <main class="page__content printable">
    <article>
      <div class="page-title">
        <h1 class="page-title__h1">Blogs, Memos, and Articles</h1>
      </div>
      <table class="blog-table">
        <thead>
          <tr>
            <th class="blog-table__heading">Date</th>
            <th class="blog-table__heading">Subject</th>
          </tr>
        </thead>
        <tbody>
          {% for item in pagination.items %}
            <tr class="blog-table__row">
              <td class="blog-table__cell blog-table__cell--time">
                <p>
                  <time
                    title="{{ item.date | blogPostTimestamp }}"
                    datetime="{{ item.date }}"
                  >
                    {{ item.date | blogListTimestamp }}
                  </time>
                </p>
              </td>
              <td class="blog-table__cell">
                <div class="blog-table__cell-content">
                  <p>
                    <a
                      href="{{ item.page.url }}"
                      title="{{ item.data.title }}"
                    >
                      {{ item.data.title }}
                    </a>
                  </p>
                  <p>{{ item.data.brief }}</p>
                  <div class="blog-table__read-post">
                    <a
                      href="{{ item.page.url }}"
                      class="blog-table__read-post-link"
                      title="{{ item.data.title }}"
                    >
                      Read Post
                    </a>
                  </div>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </article>
    <nav class="blog-nav">
      <ul class="blog-nav__link-list">
        {% if pagination.previousPageLink %}
          <li>
            <a class="blog-nav__link" href="{{ pagination.previousPageLink }}">
              Previous
            </a>
          </li>
        {% endif %}
        {% if pagination.nextPageLink %}
          <li>
            <a class="blog-nav__link" href="{{ pagination.nextPageLink }}">
              Next
            </a>
          </li>
        {% endif %}
      </ul>
    </nav>
  </main>
{% endblock %}
